# ═══════════════════════════════════════════════════════════
# MAFURIKO AI - .gitignore
# ═══════════════════════════════════════════════════════════

# Python Virtual Environment
venv/
env/
ENV/
.venv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.pyo

# Environment Variables (SECRETS!)
.env
.env.local
.env.production
.env.development

# Databases
*.db
*.sqlite
*.sqlite3
mafuriko.db

# Machine Learning Models (too large for GitHub)
*.pkl
models/*.pkl
services/ml/*.pkl

# Kaggle files (if downloaded)
best_flood_model.pkl
scaler.pkl
encoders.pkl
metadata.json

# Data files (too large)
data/raw/*.csv
data/processed/*.csv
data/*.csv
*.csv

# IDE Settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS Files
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Logs
*.log
logs/
log/

# Docker
docker-compose.override.yml
*.pid

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Cache
cache/
.cache/
.pytest_cache/

# Distribution / Build
dist/
build/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# Backup files
*.bak
*.backup
*~

# Load test results (optional - keep or remove)
load_test_results.json